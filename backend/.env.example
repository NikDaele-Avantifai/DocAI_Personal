# ── App ──────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-secret

# ── Database (PostgreSQL on Azure) ───────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/docai

# ── Azure Entra ID (Auth) ─────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── OpenAI (LLM backend for LangGraph) ───────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Confluence ────────────────────────────────────────────────
# These are set per-user via the dashboard, not globally
# CONFLUENCE_BASE_URL=https://yourorg.atlassian.net
# CONFLUENCE_API_TOKEN=your-api-token
