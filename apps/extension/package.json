{
  "name": "@docai/extension",
  "version": "0.1.0",
  "private": true,
  "description": "DocAI browser extension",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "plasmo": "0.89.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@docai/shared-types": "*"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  },
  "manifest": {
    "host_permissions": [
      "https://*.atlassian.net/*"
    ],
    "permissions": [
      "storage",
      "activeTab"
    ]
  }
}
